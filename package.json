{
	"name": "cno-plugin-cnhsa-content-federation",
	"version": "1.1.3",
	"description": "The plugin for CNHSA content federation.",
	"author": "Choctaw Nation of Oklahoma",
	"license": "GPL-3.0-or-later",
	"prettier": "@wordpress/prettier-config",
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"files": [
		"inc/",
		"cno-plugin-cnhsa-content-federation.php",
		"README.md",
		"build/",
		"LICENSE",
		"vendor/"
	],
	"engines": {
		"node": ">= 24",
		"npm": ">= 11"
	},
	"allowScripts": {
		"@parcel/watcher@2.5.6": true,
		"core-js@3.49.0": true,
		"core-js-pure@3.48.0": true,
		"fsevents@2.3.3": true,
		"fsevents@2.3.2": true,
		"unrs-resolver@1.11.1": true
	},
	"scripts": {
